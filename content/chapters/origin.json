{
  "$schema": "../schemas/content-pack.schema.json",
  "schemaVersion": 1,
  "id": "evolution.origin",
  "version": "0.1.0",
  "title": "原点：从零维混沌到首个三维领域",
  "license": "GPL-3.0-or-later",
  "source": {
    "repository": "https://github.com/GIT-HPW/Evolution-",
    "chapters": [
      "第1章 第1篇 原点：一切的源",
      "第1章 第2篇 时空：宇宙的格局"
    ],
    "adaptation": "规则化改编：把原始能量信息体、熵增、撕裂、融合和大爆炸转化为可重复游玩的状态机。"
  },
  "initialState": {
    "schema": 1,
    "phase": "origin_0d",
    "dimension": 0,
    "energy": 24,
    "information": 0,
    "entropy": 0,
    "stability": 12,
    "fragments": 0,
    "timeline": "origin",
    "steps": 0
  },
  "limits": {
    "energy": { "min": 0, "max": 999 },
    "information": { "min": 0, "max": 999 },
    "entropy": { "min": 0, "max": 999 },
    "stability": { "min": 0, "max": 100 },
    "fragments": { "min": 0, "max": 999 },
    "steps": { "min": 0, "max": 999999 }
  },
  "phases": [
    {
      "id": "origin_0d",
      "dimension": 0,
      "title": "零维原点",
      "objective": "观察混沌、主动撕裂并积累足够的信息与熵，触发大爆炸。"
    },
    {
      "id": "first_3d",
      "dimension": 3,
      "title": "首个三维领域",
      "objective": "创造、毁灭和稳定原始物质，并建立自己的时间线分支。"
    }
  ],
  "actions": {
    "observe": {
      "title": "观察混沌",
      "availableIn": ["origin_0d", "first_3d"],
      "delta": { "information": 3, "entropy": 2, "stability": -1 },
      "result": "认知增加，但观察本身改变了系统。"
    },
    "split": {
      "title": "撕裂自身",
      "availableIn": ["origin_0d"],
      "requires": { "energy": 4, "stability": 2 },
      "delta": { "energy": -4, "entropy": 3, "stability": -2, "fragments": 2 },
      "result": "整体控制减弱，能量信息碎片出现。"
    },
    "fuse": {
      "title": "融合碎片",
      "availableIn": ["origin_0d"],
      "requires": { "fragments": 1 },
      "delta": { "energy": 3, "information": 1, "entropy": -1, "stability": 2, "fragments": -1 },
      "result": "一次局部自我更新完成。"
    },
    "big_bang": {
      "title": "触发大爆炸",
      "availableIn": ["origin_0d"],
      "requires": { "information": 12, "entropy": 12, "fragments": 2 },
      "delta": { "energy": 8, "entropy": -6, "stability": 6 },
      "set": { "phase": "first_3d", "dimension": 3 },
      "result": "混沌体破裂，时间、空间与首个三维领域形成。"
    },
    "create": {
      "title": "创造物质",
      "availableIn": ["first_3d"],
      "requires": { "energy": 2 },
      "delta": { "energy": -2, "information": 1, "entropy": 1 },
      "result": "能量凝聚为可塑的原始物质。"
    },
    "destroy": {
      "title": "毁灭物质",
      "availableIn": ["first_3d"],
      "delta": { "energy": 1, "entropy": 2, "stability": -1 },
      "result": "物质回归能量，系统熵继续增长。"
    },
    "stabilize": {
      "title": "稳定时空",
      "availableIn": ["first_3d"],
      "requires": { "energy": 1, "information": 2 },
      "delta": { "energy": -1, "information": -2, "entropy": -2, "stability": 3 },
      "result": "以能量和认知换取局部时空稳定。"
    }
  },
  "demo": ["observe", "observe", "observe", "observe", "split", "split", "big_bang"]
}
