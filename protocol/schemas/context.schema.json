{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://git-hpw.github.io/EvolutionSandbox/esip/schemas/context.schema.json",
  "title": "Evolution routing context",
  "type": "object",
  "required": ["universeId", "timelineId"],
  "properties": {
    "universeId": { "$ref": "#/$defs/id" },
    "timelineId": { "$ref": "#/$defs/id" },
    "realmId": { "$ref": "#/$defs/id" },
    "actorId": { "$ref": "#/$defs/id" }
  },
  "additionalProperties": false,
  "$defs": {
    "id": { "type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$" }
  }
}
