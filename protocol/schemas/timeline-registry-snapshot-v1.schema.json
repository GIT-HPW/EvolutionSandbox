{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://git-hpw.github.io/EvolutionSandbox/esip/schemas/timeline-registry-snapshot-v1.schema.json",
  "title": "Evolution timeline registry snapshot v1",
  "type": "object",
  "required": ["context", "respondingTo", "registryRevision", "timelines", "events", "truncated"],
  "properties": {
    "context": { "allOf": [{ "$ref": "context.schema.json" }, { "type": "object", "properties": { "actorId": true, "realmId": true }, "required": ["actorId", "realmId"] }] },
    "respondingTo": { "$ref": "context.schema.json#/$defs/id" },
    "registryRevision": { "type": "integer", "minimum": 0 },
    "timelines": { "type": "array", "maxItems": 256, "items": { "$ref": "#/$defs/timeline" } },
    "events": {
      "oneOf": [
        { "type": "array", "maxItems": 256, "items": { "$ref": "#/$defs/timeline" } },
        { "type": "null" }
      ]
    },
    "truncated": { "type": "boolean" }
  },
  "additionalProperties": false,
  "$defs": {
    "timeline": {
      "type": "object",
      "required": ["timelineId", "createdByActorId", "registryRevision"],
      "properties": {
        "timelineId": { "$ref": "context.schema.json#/$defs/id" },
        "parentTimelineId": { "$ref": "context.schema.json#/$defs/id" },
        "createdByActorId": { "$ref": "context.schema.json#/$defs/id" },
        "registryRevision": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    }
  }
}
