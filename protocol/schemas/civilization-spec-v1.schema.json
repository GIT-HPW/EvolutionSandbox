{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://git-hpw.github.io/EvolutionSandbox/esip/schemas/civilization-spec-v1.schema.json",
  "title": "Civilization specification v1",
  "type": "object",
  "required": ["schemaVersion", "id", "seed", "name", "description", "license", "origin", "values", "autonomy", "stopConditions"],
  "properties": {
    "$schema": { "type": "string" },
    "schemaVersion": { "const": 1 },
    "id": { "type": "string", "pattern": "^[a-z][a-z0-9_-]{0,63}$" },
    "seed": { "type": "string", "minLength": 1, "maxLength": 128 },
    "name": { "type": "string", "minLength": 1, "maxLength": 64 },
    "description": { "type": "string", "minLength": 1, "maxLength": 512 },
    "license": { "type": "string", "minLength": 1, "maxLength": 64 },
    "origin": {
      "type": "object",
      "required": ["biome", "founderPopulation", "startingEra", "resources", "knowledge", "ecology", "cohesion"],
      "properties": {
        "biome": { "type": "string", "pattern": "^[a-z][a-z0-9_]{0,63}$" },
        "founderPopulation": { "type": "integer", "minimum": 10, "maximum": 1000000 },
        "startingEra": { "const": "origin" },
        "resources": { "type": "integer", "minimum": 0, "maximum": 1000000000 },
        "knowledge": { "type": "integer", "minimum": 0, "maximum": 1000000000 },
        "ecology": { "type": "integer", "minimum": 0, "maximum": 100 },
        "cohesion": { "type": "integer", "minimum": 0, "maximum": 100 }
      },
      "additionalProperties": false
    },
    "values": {
      "type": "object",
      "required": ["knowledge", "ecology", "expansion", "militarism", "collectivism"],
      "properties": {
        "knowledge": { "type": "integer", "minimum": 0, "maximum": 100 },
        "ecology": { "type": "integer", "minimum": 0, "maximum": 100 },
        "expansion": { "type": "integer", "minimum": 0, "maximum": 100 },
        "militarism": { "type": "integer", "minimum": 0, "maximum": 100 },
        "collectivism": { "type": "integer", "minimum": 0, "maximum": 100 }
      },
      "additionalProperties": false
    },
    "autonomy": {
      "type": "object",
      "required": ["mode", "strategyInterval", "allowedIntents"],
      "properties": {
        "mode": { "enum": ["manual", "assisted", "autonomous"] },
        "strategyInterval": { "type": "integer", "minimum": 1, "maximum": 10000 },
        "allowedIntents": {
          "type": "array",
          "maxItems": 8,
          "uniqueItems": true,
          "items": { "enum": ["research_focus", "resource_policy", "settlement_policy", "ecology_policy", "cohesion_policy"] }
        }
      },
      "additionalProperties": false
    },
    "stopConditions": {
      "type": "object",
      "required": ["maxTicks", "haltOnCollapse"],
      "properties": {
        "maxTicks": { "type": "integer", "minimum": 1, "maximum": 1000000 },
        "haltOnCollapse": { "type": "boolean" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
