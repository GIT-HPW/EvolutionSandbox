{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://git-hpw.github.io/EvolutionSandbox/esip/schemas/timeline-created-v1.schema.json",
  "title": "Evolution timeline creation event v1",
  "type": "object",
  "required": ["context", "parentTimelineId", "newTimelineId", "branchRevision"],
  "properties": {
    "context": { "allOf": [{ "$ref": "context.schema.json" }, { "type": "object", "properties": { "actorId": true, "realmId": true }, "required": ["actorId", "realmId"] }] },
    "parentTimelineId": { "type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$" },
    "newTimelineId": { "type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$" },
    "branchRevision": { "type": "integer", "minimum": 0 }
  },
  "additionalProperties": false
}
