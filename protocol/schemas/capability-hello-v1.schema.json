{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://git-hpw.github.io/EvolutionSandbox/esip/schemas/capability-hello-v1.schema.json",
  "title": "ESIP adapter capability announcement v1",
  "type": "object",
  "required": ["adapterId", "platform", "protocolVersions", "consumes", "produces", "maxMessageBytes"],
  "properties": {
    "adapterId": { "type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$" },
    "platform": { "type": "string", "minLength": 1, "maxLength": 64 },
    "protocolVersions": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+$" } },
    "consumes": { "$ref": "#/$defs/patterns" },
    "produces": { "$ref": "#/$defs/patterns" },
    "maxMessageBytes": { "type": "integer", "minimum": 1024, "maximum": 16777216 }
  },
  "additionalProperties": false,
  "$defs": {
    "patterns": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1, "maxLength": 128 } }
  }
}
