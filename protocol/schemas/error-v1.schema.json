{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://git-hpw.github.io/EvolutionSandbox/esip/schemas/error-v1.schema.json",
  "title": "ESIP error result v1",
  "type": "object",
  "required": ["respondingTo", "code", "message", "retryable"],
  "properties": {
    "respondingTo": { "type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$" },
    "code": { "type": "string", "minLength": 1, "maxLength": 64, "pattern": "^[a-z][a-z0-9_]*$" },
    "message": { "type": "string", "minLength": 1, "maxLength": 512 },
    "retryable": { "type": "boolean" }
  },
  "additionalProperties": false
}
